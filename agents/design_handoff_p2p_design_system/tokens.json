{
  "$schema": "https://design-tokens.org/format",
  "name": "Peer to Peer Design System",
  "identity": "Editorial · grayscale + single vermillion accent",
  "color": {
    "light": {
      "bg": "#E9E9E9",
      "surface": "#F7F7F7",
      "surface-2": "#E7E7E7",
      "tint": "#DEDEDE",
      "ink": "#171717",
      "ink-soft": "#565656",
      "ink-faint": "#8A8A8A",
      "line": "#DADADA",
      "line-strong": "#C4C4C4",
      "accent": "#D83A1A",
      "accent-deep": "#B22E12",
      "accent-soft": "#E6E6E6",
      "on-accent": "#FFFFFF",
      "hero-bg": "#181818",
      "hero-ink": "#ECECEC",
      "hero-line": "#2F2F2F",
      "second": "#2A2A2A",
      "second-soft": "#E0E0E0"
    },
    "dark": {
      "bg": "#0F0F0F",
      "surface": "#191919",
      "surface-2": "#202020",
      "tint": "#262626",
      "ink": "#ECECEC",
      "ink-soft": "#A6A6A6",
      "ink-faint": "#6E6E6E",
      "line": "#2C2C2C",
      "line-strong": "#3C3C3C",
      "accent": "#E8472A",
      "accent-deep": "#C42E12",
      "accent-soft": "#242424",
      "on-accent": "#FFFFFF",
      "hero-bg": "#000000",
      "hero-ink": "#ECECEC",
      "hero-line": "#2A2A2A",
      "second": "#ECECEC",
      "second-soft": "#242424"
    }
  },
  "typography": {
    "fontDisplay": "'Newsreader', Georgia, serif",
    "fontBody": "'Hanken Grotesk', system-ui, sans-serif",
    "displayWeight": 500,
    "scale": {
      "display": { "size": "clamp(40px, 5vw, 60px)", "lineHeight": 0.98, "letterSpacing": "-0.02em", "family": "display" },
      "h2": { "size": "clamp(24px, 2.4vw, 32px)", "lineHeight": 1.1, "family": "display" },
      "h3": { "size": "20px", "lineHeight": 1.2, "family": "display" },
      "stat": { "size": "40px", "lineHeight": 1, "family": "display", "color": "accent" },
      "body": { "size": "15px", "lineHeight": 1.55, "family": "body" },
      "bodySmall": { "size": "14px", "lineHeight": 1.5, "family": "body", "color": "ink-soft" },
      "eyebrow": { "size": "11px", "weight": 600, "letterSpacing": "0.14em", "transform": "uppercase", "family": "body", "color": "accent" }
    }
  },
  "geometry": {
    "name": "Net",
    "radius": "5px",
    "radiusSmall": "4px",
    "borderWidth": "1px",
    "shadow": "none"
  },
  "spacing": {
    "cardPaddingY": "22px",
    "cardPaddingX": "24px",
    "gridGap": "14px",
    "gridColumns": 12
  },
  "motion": {
    "ease": "cubic-bezier(.2,.6,.2,1)",
    "hover": "0.2s",
    "themeSwitch": "instant (disable transitions during swap)"
  }
}
